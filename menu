local THEME_COLOR = Color3.fromRGB(0,255,200)

--// SAVE
local saveFile = "jekak_ui_pos.txt"

local function savePos(pos)
    if writefile then
        writefile(saveFile, game:GetService("HttpService"):JSONEncode({
            x=pos.X.Scale,y=pos.Y.Scale,ox=pos.X.Offset,oy=pos.Y.Offset
        }))
    end
end

local function loadPos(default)
    if readfile and isfile and isfile(saveFile) then
        local data = game:GetService("HttpService"):JSONDecode(readfile(saveFile))
        return UDim2.new(data.x,data.ox,data.y,data.oy)
    end
    return default
end

